{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@eventpulse/shared": ["./packages/shared/src"]
    }
  },
  "include": ["."],
  "exclude": ["dist", "node_modules", "packages/shared/dist"]
}
